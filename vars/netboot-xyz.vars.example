# App-specific defaults for netboot.xyz (netboot-xyz)
# Generated on 2026-05-10T22:30:02Z

var_os=debian
var_version=13
var_unprivileged=1
var_cpu=1
var_ram=512
var_disk=8
var_brg=vmbr0
var_net=dhcp
var_mac=<insert desired MAC address OR leave blank to auto-generate>
var_ipv6_method=none
var_ssh=yes
var_apt_cacher=no
var_fuse=yes
var_tun=no
var_gpu=no
var_nesting=1
var_keyctl=1
var_mknod=0
var_protection=no
var_timezone=America/New_York
var_tags=<insert desired tags OR leave blank for default>
var_verbose=no
var_hostname=hml-netboot
var_template_storage=local
var_container_storage=local-lvm